# ─────────────────────────────────────────────────────────────────────────────
#  XWiki Unified Uploader  —  Environment Configuration Template
#
#  USAGE:
#    cp .env.example .env
#    Edit .env with your real values (never commit .env to git).
# ─────────────────────────────────────────────────────────────────────────────


# ── LOCAL SOURCE ──────────────────────────────────────────────────────────────
# Absolute path to the file OR folder you want to upload.
# Examples:
#   A single file : /Users/mallesh/Downloads/BigVideo.mp4
#   A folder      : /Users/mallesh/Downloads/KT Recordings
LOCAL_SOURCE_PATH=/Users/mallesh/Downloads/KT Recordings  # replace with the your local path


# ── EC2 / SSH ─────────────────────────────────────────────────────────────────
# The EC2 instance where XWiki (Tomcat) is running.
# Format: user@hostname  (ubuntu is typical for AWS EC2 Ubuntu AMIs)
EC2_HOST=ubuntu@ec2-XX-XX-XX-XX.ap-south-1.compute.amazonaws.com

# Absolute path to your .pem key file on your LOCAL Mac.
EC2_SSH_KEY=/path-to-the-file/Incepta-Ai.pem

# Temporary staging directory on the EC2 instance.
# Files are copied here via SCP, then uploaded to XWiki, then deleted.
# The directory is created automatically if it does not exist.
EC2_TEMP_DIR=/home/ubuntu/xwiki_upload_staging


# ── XWIKI (TWO URLs — both are required, each serves a different purpose) ────
#
# XWIKI_PUBLIC_URL  →  Your public-facing XWiki domain.
#   Used by the script running on your LOCAL Mac for:
#     • Checking if XWiki pages already exist (HEAD request)
#     • Creating new XWiki pages (small XML PUT, not a file upload)
#     • Checking if attachments already exist (HEAD request)
#     • Post-upload verification (HEAD request)
#   These are tiny API calls — Cloudflare's 100 MB limit does NOT apply here.
#   It only blocks file upload bodies, not REST metadata calls.
XWIKI_PUBLIC_URL=https://msdocs.bootlabstech.com/xwiki

# XWIKI_BASE_URL  →  Always http://localhost:8080/xwiki
#   Used ONLY inside the Python snippet that runs ON EC2 via SSH.
#   The actual file bytes are PUT to localhost from inside EC2, so they
#   never pass through Cloudflare at all — no size limit.
#   Do NOT change this unless your Tomcat port is different.
XWIKI_BASE_URL=http://localhost:8080/xwiki

# Your XWiki session cookie value.
# How to get it:
#   1. Open XWiki in your browser and log in (SSO is fine).
#   2. Press F12 → Application tab → Cookies.
#   3. Copy the VALUE of the cookie named JSESSIONID.
# Note: This expires when you log out or after the session timeout.
#       Refresh it whenever you get a 401 Unauthorized error.
JSESSIONID=PASTE_YOUR_JSESSIONID_VALUE_HERE


# ── DRY RUN ───────────────────────────────────────────────────────────────────
# Set to true to preview all uploads without making any changes.
# Set to false for live upload.
# Can also be overridden by passing --dry-run on the command line.
DRY_RUN=false
